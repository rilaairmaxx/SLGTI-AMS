# ── SLGTI Attendance Management System ──
# Block direct browser access to sensitive directories

# Deny access to includes/ and config/
<IfModule mod_authz_core.c>
    # Apache 2.4+
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to PHP files inside includes/ and config/ directly
<FilesMatch "\.(php|inc|json|lock)$">
    # Default: allow (overridden per-directory below)
</FilesMatch>

# Protect .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>

# Protect composer files
<FilesMatch "^(composer\.(json|lock))$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
